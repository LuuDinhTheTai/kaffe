# Supabase Database settings (copy into your local env, do not commit secrets)

# Spring Boot JDBC URL (host/port/db only)
DATABASE_URL=jdbc:postgresql://aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require

# Optional variables (used only for username/password binding outside the URL)
SUPABASE_DB_USER=postgres.your-project-ref
SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD

# Optional tuning
SUPABASE_DB_POOL_SIZE=10
SPRING_JPA_DDL_AUTO=update
